  "CreateScheduleDto": {
    "type": "object",
    "properties": {
      "diaSemana": {
        "type": "number",
        "description": "El día de la semana (0=Domingo, 6=Sábado)",
        "example": 1,
        "minimum": 0,
        "maximum": 6
      },
      "horaInicio": {
        "type": "string",
        "description": "Hora de inicio en formato HH:MM",
        "example": "08:00",
        "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
      },
      "horaFin": {
        "type": "string",
        "description": "Hora de fin en formato HH:MM",
        "example": "17:00",
        "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$"
      },
      "doctorId": {
        "type": "string",
        "description": "ID del doctor",
        "example": "uuid-del-doctor"
      },
      "consultingRoomId": {
        "type": "string",
        "description": "ID del consultorio",
        "example": "uuid-del-consultorio"
      }
    },
    "required": [
      "diaSemana",
      "horaInicio",
      "horaFin",
      "doctorId",
      "consultingRoomId"
    ]
  },
