  "CreateAppointmentDto": {
    "type": "object",
    "properties": {
      "patientId": {
        "type": "string",
        "example": "uuid-of-patient",
        "description": "The ID of the patient"
      },
      "doctorId": {
        "type": "string",
        "example": "uuid-of-doctor",
        "description": "The ID of the doctor"
      },
      "consultingRoomId": {
        "type": "string",
        "example": "uuid-of-consulting-room",
        "description": "The ID of the consulting room"
      },
      "startTime": {
        "format": "date-time",
        "type": "string",
        "example": "2023-10-27T10:00:00Z",
        "description": "The start time of the appointment"
      },
      "endTime": {
        "format": "date-time",
        "type": "string",
        "example": "2023-10-27T11:00:00Z",
        "description": "The end time of the appointment"
      },
      "status": {
        "type": "string",
        "enum": [
          "SCHEDULED",
          "COMPLETED",
          "CANCELLED"
        ],
        "description": "The status of the appointment"
      },
      "reason": {
        "type": "string",
        "example": "Regular checkup",
        "description": "The reason for the appointment"
      },
      "notes": {
        "type": "string",
        "example": "Patient prefers morning appointments",
        "description": "Additional notes"
      }
    },
    "required": [
      "patientId",
      "doctorId",
      "consultingRoomId",
      "startTime",
      "endTime"
    ]
  },
